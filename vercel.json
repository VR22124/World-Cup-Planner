{
  "name": "world-cup-planner",
  "version": 2,
  "outputDirectory": "apps/web/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://world-cup-planner-api.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
